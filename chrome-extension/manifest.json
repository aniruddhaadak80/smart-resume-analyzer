{
  "manifest_version": 3,
  "name": "careerzen Resume Optimizer",
  "version": "1.0",
  "description": "Analyze LinkedIn job postings against your resume with a single click using careerzen.",
  "permissions": [
    "activeTab",
    "scripting",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "*://*.linkedin.com/*",
    "*://careerzen.vercel.app/*",
    "http://localhost:3000/*"
  ],
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.linkedin.com/jobs/*"],
      "js": ["content/linkedin.js"],
      "css": ["content/linkedin.css"]
    },
    {
      "matches": ["*://careerzen.vercel.app/*", "http://localhost:3000/*"],
      "js": ["content/careerzen.js"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "careerzen Optimizer"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
