generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Resume {
  id        String   @id @default(uuid())
  userId    String   // Store Clerk User ID directly
  fileName  String
  jobTitle  String?
  matchScore Int?
  fileUrl   String
  fileType  String   // "PDF" or "DOCX"
  content   String? // Optional: store full JSON content for strict retrieval
  actionType String  @default("OPTIMIZE") // "OPTIMIZE" | "ANALYZE" | "COACH"
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

model JobApplication {
  id          String   @id @default(uuid())
  userId      String
  jobTitle    String
  company     String
  location    String?
  jobUrl      String?
  status      String   @default("wishlist") // wishlist | applied | interviewing | offer | rejected
  notes       String?
  salary      String?
  appliedDate DateTime?
  color       String?  // Optional color tag for visual distinction
  position    Int      @default(0) // For ordering within a column
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([userId, status])
}

model UserActivity {
  id          String   @id @default(uuid())
  userId      String
  actionType  String   // LOGIN, SIGNUP, ANALYZE, OPTIMIZE, TRACKER, COACH, CHAT
  details     String?  // JSON stringified additional context
  createdAt   DateTime @default(now())

  @@index([userId, createdAt(sort: Desc)])
}
